[GeneralColors]
window.color={{ colors.surface.default.hex }}
window.text.color={{ colors.on_surface.default.hex }}
button.color={{ colors.primary.default.hex }}
button.text.color={{ colors.on_primary.default.hex }}
highlight.color={{ colors.secondary.default.hex }}
highlight.text.color={{ colors.on_secondary.default.hex }}
tooltip.color={{ colors.surface_variant.default.hex }}
tooltip.text.color={{ colors.on_surface_variant.default.hex }}

