vim.api.nvim_create_autocmd("User", {
  pattern = "MatugenReloaded",
  callback = function()
    -- clear cached palette
    package.loaded["carwash.palette"] = nil
    local colors = require("carwash.palette")

    -- clear cached groups
    package.loaded["carwash.groups"] = nil
    local groups = require("carwash.groups")

    -- reapply highlights
    local hl = groups.setup()
    for group, opts in pairs(hl) do
      vim.api.nvim_set_hl(0, group, opts)
    end
  end,
})
